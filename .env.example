# Copy to .env.local and fill in. Never commit real values.

# --- Supabase (Milestone 2) -------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Milestone 4) ---------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Maps Platform — Photorealistic 3D Tiles hero (§3a) --------------
# Requires an API key with billing enabled. When absent, the app falls back
# to the static retouched aerial hero via the feature flag below.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_FEATURE_3D_HERO=false

# --- Streaming provider (Milestone 6) — pick one behind StreamProvider ------
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# or: CLOUDFLARE_STREAM_ACCOUNT_ID= / YouTube Live video IDs in DB

# --- Newsletter email delivery (Milestone 5) --------------------------------
RESEND_API_KEY=

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
